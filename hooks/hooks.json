{
  "description": "Refresh the local usage projection and emit one-time attention notices.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-watch hook session-start",
            "timeout": 5,
            "statusMessage": "Updating local usage watch"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-watch hook user-prompt-submit",
            "timeout": 5,
            "statusMessage": "Updating local usage watch"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-watch hook stop",
            "timeout": 5,
            "statusMessage": "Saving local usage watch"
          }
        ]
      }
    ]
  }
}
